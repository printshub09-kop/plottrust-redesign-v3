# ── Database (PostgreSQL + PostGIS) ─────────────────────────────────
DATABASE_URL="postgresql://user:pass@localhost:5432/plottrust?schema=public"

# ── Redis (caching 7/12 + RR rates) ─────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth (NextAuth / Clerk / Supabase) ──────────────────────────────
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ── External integrations ───────────────────────────────────────────
# Mahabhulekh scraper token (if using your own proxy service)
MAHABHUMI_API_KEY=""
MAHARERA_API_KEY=""

# Razorpay (payments for ₹500 tokens / subscriptions)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# WhatsApp Business API (Gupshup / Meta Cloud)
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# Map tiles — Mapbox or MapmyIndia
NEXT_PUBLIC_MAPBOX_TOKEN=""
NEXT_PUBLIC_MAPMYINDIA_KEY=""

# Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="plottrust.in"

# Uploads (Cloudflare R2 / AWS S3)
S3_BUCKET="plottrust-uploads"
S3_REGION="ap-south-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
