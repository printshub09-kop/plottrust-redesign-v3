// PlotTrust — Prisma schema
// Models are optimized for the Maharashtra land-records domain:
// District → Taluka → Village → Plot (Gat / Survey / CTS)
// with ASR rates, mutations (Ferfar), lookups (for billing), cases, and RERA.
//
// PostGIS geometry columns are declared via `Unsupported("geometry")`.
// Enable the extension once per database:
//   CREATE EXTENSION IF NOT EXISTS postgis;

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// ────────────────────────────────────────────────────────────────────────
// AUTH & BILLING
// ────────────────────────────────────────────────────────────────────────
enum UserRole {
  CONSUMER     // walk-in buyer / seller
  BROKER
  BUILDER
  LAWYER
  AGENT
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phoneE164    String?  @unique
  name         String
  role         UserRole @default(CONSUMER)
  marathiPref  Boolean  @default(true)
  credits      Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  plotsListed  Plot[]         @relation("PlotOwner")
  lookups      Lookup[]
  cases        Case[]         @relation("CaseOwner")
  teamOf       TeamMember[]
  subscription Subscription?

  @@index([role])
}

model Subscription {
  id         String   @id @default(cuid())
  userId     String   @unique
  plan       String   // 'free' | 'pro' | 'agency' | 'enterprise'
  seats      Int      @default(1)
  renewsOn   DateTime?
  status     String   @default("active") // 'active' | 'paused' | 'cancelled'
  user       User     @relation(fields: [userId], references: [id])
}

model TeamMember {
  id        String @id @default(cuid())
  userId    String
  teamId    String
  role      String // 'owner' | 'editor' | 'viewer'
  user      User   @relation(fields: [userId], references: [id])

  @@unique([userId, teamId])
}

// ────────────────────────────────────────────────────────────────────────
// GEO: DISTRICT → TALUKA → VILLAGE
// ────────────────────────────────────────────────────────────────────────
model District {
  id       String   @id @default(cuid())
  name     String
  nameMr   String?                  // Marathi name
  lgdCode  String   @unique         // Local Government Directory code
  talukas  Taluka[]

  @@index([name])
}

model Taluka {
  id         String    @id @default(cuid())
  name       String
  nameMr     String?
  lgdCode    String    @unique
  districtId String
  district   District  @relation(fields: [districtId], references: [id])
  villages   Village[]

  @@index([districtId, name])
}

model Village {
  id              String  @id @default(cuid())
  name            String
  nameMr          String?
  lgdCode         String  @unique
  talukaId        String
  pincode         String?
  // Polygon boundary (PostGIS SRID 4326). Run: ALTER TABLE "Village" ALTER COLUMN boundary TYPE geometry(MultiPolygon, 4326);
  boundary        Unsupported("geometry(MultiPolygon,4326)")?
  centroidLat     Float?
  centroidLng     Float?

  taluka          Taluka              @relation(fields: [talukaId], references: [id])
  plots           Plot[]
  reckonerRates   ReadyReckonerRate[]

  @@index([talukaId, name])
  @@index([name])
}

// ────────────────────────────────────────────────────────────────────────
// PLOT
// ────────────────────────────────────────────────────────────────────────
enum LandType {
  NA                 // Non-Agricultural (Residential default)
  AGRI               // Agricultural
  AGRI_NA_POTENTIAL  // Agri land in NA-convertible zone
  MIXED
  RESERVED           // DP/TP reservation (school, road, garden…)
}

enum DpZone {
  green
  yellow
  red
}

model Plot {
  id                String     @id @default(cuid())
  slug              String     @unique
  villageId         String
  village           Village    @relation(fields: [villageId], references: [id])

  gatNumber         String?
  surveyNumber      String?
  ctsNumber         String?
  reraNumber        String?

  areaSqm           Float
  frontRoadMeters   Int?
  landType          LandType
  dpZone            DpZone
  reservation       String?    // "Primary School", "24m DP Road", etc.
  fsiAllowed        Float?
  tdrAllowed        Float?

  readyReckonerRate Int        // ₹ / sq.m (snapshot at time of listing)
  askMarketRate     Int?       // ₹ / sq.m (seller quote)
  lastTxnRate       Int?       // ₹ / sq.m (nearest registered txn)

  // Geometry (PostGIS). Typically a Polygon in SRID 4326.
  boundary          Unsupported("geometry(Polygon,4326)")?

  verified          Boolean    @default(false)
  source            String     @default("owner")  // owner | broker | scraped | partner
  ownerId           String?
  owner             User?      @relation("PlotOwner", fields: [ownerId], references: [id])
  images            PlotImage[]
  transactions      Transaction[]
  cases             Case[]
  listedAt          DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([villageId, landType, dpZone])
  @@index([dpZone])
  @@index([gatNumber])
  @@index([surveyNumber])
  @@index([reraNumber])
}

model PlotImage {
  id        String   @id @default(cuid())
  plotId    String
  plot      Plot     @relation(fields: [plotId], references: [id], onDelete: Cascade)
  url       String
  kind      String   // 'village_map' | 'layout_plan' | 'building_plan' | 'satellite' | 'photo'
  width     Int?
  height    Int?
  caption   String?
  createdAt DateTime @default(now())
}

// ────────────────────────────────────────────────────────────────────────
// ASR / READY RECKONER
// ────────────────────────────────────────────────────────────────────────
enum AsrLandType {
  NA_RES
  NA_COM
  AGRI
  INDUSTRIAL
}

model ReadyReckonerRate {
  id           String      @id @default(cuid())
  villageId    String
  year         Int
  landType     AsrLandType
  ratePerSqm   Int
  notes        String?
  sourceUrl    String?
  village      Village     @relation(fields: [villageId], references: [id])

  @@unique([villageId, year, landType])
  @@index([year, landType])
}

// ────────────────────────────────────────────────────────────────────────
// TRANSACTIONS (sales from IGR)
// ────────────────────────────────────────────────────────────────────────
model Transaction {
  id             String   @id @default(cuid())
  plotId         String?
  plot           Plot?    @relation(fields: [plotId], references: [id])
  // Denormalized location, since some IGR rows cannot be joined to a Plot.
  villageName    String?
  taluka         String?
  district       String?

  saleValue      BigInt        // ₹ (use BigInt to be safe for crore-scale)
  pricePerSqm    Int?
  areaSqm        Float?
  documentNo     String?  @unique
  registeredAt   DateTime
  rawSource      String?  // "IGR eSBTR 2026-03"

  @@index([registeredAt])
  @@index([villageName])
}

// ────────────────────────────────────────────────────────────────────────
// OPERATIONS: LOOKUPS + CASES
// ────────────────────────────────────────────────────────────────────────
model Lookup {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  kind       String   // '712' | '8A' | 'propertycard' | 'ferfar' | 'rr' | 'zone'
  key        String   // normalized cache key
  creditsUsed Int     @default(1)
  status     String   @default("ok")  // ok | failed | cached
  latencyMs  Int?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([kind, createdAt])
}

enum CaseStatus {
  DRAFT
  IN_PROGRESS
  WAITING_TAHSILDAR
  WAITING_REGISTRAR
  BLOCKED
  CLOSED
}

model Case {
  id          String     @id @default(cuid())
  ownerId     String
  owner       User       @relation("CaseOwner", fields: [ownerId], references: [id])
  plotId      String?
  plot        Plot?      @relation(fields: [plotId], references: [id])
  title       String
  summary     String?
  status      CaseStatus @default(DRAFT)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([ownerId, status])
}
